    "low body temperature",
    "difficulty staying conscious"
  ],
  "red_flags": [
    "unconsciousness",
    "breathing fewer than eight breaths per minute",
    "gaps greater than 10 seconds between breaths",
    "repeated vomiting with reduced consciousness",
    "seizures after alcohol intake",
    "suspected ingestion of toxic alcohol"
  ],
  "common_causes": [
    "binge drinking",
    "rapid consumption of large alcohol amounts",
    "ingestion of mouthwash or household alcohol products",
    "isopropyl alcohol ingestion",
    "methanol ingestion",
    "ethylene glycol ingestion"
  ],
  "risk_factors": [
    "binge drinking behavior",
    "low body weight",
    "drinking on an empty stomach",
    "concurrent drug use",
    "use of alcohol-containing household products",
    "young age or inexperience with alcohol",
    "medical conditions affecting alcohol metabolism"
  ],
  "triage_priority": "Urgent (Within 1 Hour)",
  "actions": [
